# ─── Application ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://root:root@localhost:5432/wedding_ai_db

# ─── LLM provider switch ───────────────────────────────────────────────────────
# ollama = local Gemma via Ollama
# grok   = xAI Grok (https://console.x.ai/)  — API keys usually start with xai-
# groq   = Groq cloud (https://console.groq.com/) — API keys usually start with gsk_
LLM_PROVIDER=ollama

# Shared request settings (apply to active provider)
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=1

# ─── Ollama (when LLM_PROVIDER=ollama) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:latest

# ─── Grok / xAI (when LLM_PROVIDER=grok) ───────────────────────────────────────
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
# Examples: grok-3-mini | grok-3 | grok-4.5
GROK_MODEL=grok-3-mini

# ─── Groq (when LLM_PROVIDER=groq) ─────────────────────────────────────────────
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Examples: qwen/qwen3.6-27b | llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
GROQ_MODEL=qwen/qwen3.6-27b
# Vision model for image analysis
GROQ_VISION_MODEL=qwen/qwen3.6-27b

# ─── Embeddings (keep ollama — matches seeded pgvector dimensions) ─────────────
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ─── App Settings ──────────────────────────────────────────────────────────────
DEBUG=true
MAX_HISTORY_MESSAGES=20
